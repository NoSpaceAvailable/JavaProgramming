<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.lqc.client.controller.MainChatController"
            styleClass="root">

    <!-- Left sidebar: rooms + DMs -->
    <left>
        <VBox styleClass="sidebar" prefWidth="240">
            <HBox styleClass="sidebar-header" alignment="CENTER_LEFT">
                <Label fx:id="userBadge" text="@user" styleClass="label-title" style="-fx-font-size: 14px;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 12 16 4 16;">
                <Label text="ROOMS" style="-fx-text-fill: #8e9297; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+" styleClass="button-link"
                        style="-fx-font-size: 18px; -fx-text-fill: #b9bbbe;"
                        onAction="#handleCreateRoom"/>
                <Button text="↻" styleClass="button-link"
                        style="-fx-font-size: 14px; -fx-text-fill: #b9bbbe;"
                        onAction="#handleBrowseRooms"/>
            </HBox>
            <ListView fx:id="roomListView" styleClass="room-list" VBox.vgrow="ALWAYS" prefHeight="200"/>

            <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 12 16 4 16;">
                <Label text="DIRECT MESSAGES" style="-fx-text-fill: #8e9297; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+" styleClass="button-link"
                        style="-fx-font-size: 18px; -fx-text-fill: #b9bbbe;"
                        onAction="#handleNewDm"/>
            </HBox>
            <ListView fx:id="dmListView" styleClass="room-list" VBox.vgrow="ALWAYS" prefHeight="200"/>

            <HBox style="-fx-padding: 8 16; -fx-background-color: #292b2f;" alignment="CENTER_LEFT" spacing="8">
                <Label fx:id="connectionLabel" text="Connected" style="-fx-text-fill: #43b581; -fx-font-size: 12px;"/>
                <ComboBox fx:id="statusCombo" prefWidth="100"
                          style="-fx-background-color: #2f3136; -fx-text-fill: #dcddde;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Logout" styleClass="button-link" onAction="#handleLogout"/>
            </HBox>
        </VBox>
    </left>

    <!-- Center: chat area -->
    <center>
        <BorderPane styleClass="chat-area">
            <top>
                <HBox styleClass="chat-header" alignment="CENTER_LEFT" spacing="12">
                    <Label fx:id="conversationTitle" text="Select a room or DM" styleClass="label-title"
                           style="-fx-font-size: 16px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="leaveButton" text="Leave Room" styleClass="button-link"
                            onAction="#handleLeaveRoom" visible="false" managed="false"/>
                </HBox>
            </top>
            <center>
                <ScrollPane fx:id="messagesScrollPane" fitToWidth="true"
                            style="-fx-background: #36393f; -fx-background-color: transparent;">
                    <content>
                        <VBox fx:id="messagesBox" spacing="2" style="-fx-padding: 16 0 16 0;"/>
                    </content>
                </ScrollPane>
            </center>
            <bottom>
                <VBox styleClass="message-input-bar">
                    <padding><Insets top="8"/></padding>
                    <HBox spacing="8" alignment="CENTER">
                        <Button fx:id="attachButton" text="📎" styleClass="button-link"
                                style="-fx-font-size: 18px;" onAction="#handleAttachFile" disable="true"/>
                        <TextField fx:id="messageInput" styleClass="message-input" HBox.hgrow="ALWAYS"
                                   promptText="Send a message..." onAction="#handleSendMessage" disable="true"/>
                    </HBox>
                    <Label fx:id="uploadStatusLabel" style="-fx-text-fill: #b9bbbe; -fx-font-size: 11px;"
                           visible="false" managed="false"/>
                </VBox>
            </bottom>
        </BorderPane>
    </center>

    <!-- Right: members panel -->
    <right>
        <VBox fx:id="membersPanel" styleClass="member-panel" prefWidth="220">
            <Label fx:id="membersTitle" text="MEMBERS"
                   style="-fx-padding: 16; -fx-text-fill: #8e9297; -fx-font-size: 11px; -fx-font-weight: bold;"/>
            <ListView fx:id="memberListView" styleClass="room-list" VBox.vgrow="ALWAYS"/>
        </VBox>
    </right>

</BorderPane>
