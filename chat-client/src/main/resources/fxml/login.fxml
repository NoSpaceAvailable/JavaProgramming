<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml" styleClass="auth-wrapper"
           fx:controller="com.micord.client.controller.LoginController">

    <VBox alignment="CENTER" spacing="16">
        <padding><Insets top="40" right="20" bottom="20" left="20"/></padding>

        <VBox styleClass="auth-card" maxWidth="440" maxHeight="600" spacing="6" alignment="CENTER">

            <!-- App logo: full robot-head + "MICORD" wordmark baked into the PNG -->
            <ImageView fitWidth="160" fitHeight="160" preserveRatio="true" smooth="true">
                <image>
                    <Image url="@../images/logo.png"/>
                </image>
            </ImageView>

            <Region prefHeight="4"/>

            <Label text="Welcome back!" styleClass="label-title"/>
            <Label text="Đăng nhập để tiếp tục" styleClass="label-subtitle"/>

            <Region prefHeight="18"/>

            <Label text="TÊN ĐĂNG NHẬP"
                   style="-fx-text-fill: #b5bac1; -fx-font-size: 12px; -fx-font-weight: bold;"
                   maxWidth="Infinity" alignment="BOTTOM_LEFT"/>
            <TextField fx:id="usernameField" promptText="Nhập tên đăng nhập" maxWidth="Infinity"/>

            <Region prefHeight="4"/>

            <Label text="MẬT KHẨU"
                   style="-fx-text-fill: #b5bac1; -fx-font-size: 12px; -fx-font-weight: bold;"
                   maxWidth="Infinity" alignment="BOTTOM_LEFT"/>
            <PasswordField fx:id="passwordField" promptText="Nhập mật khẩu" maxWidth="Infinity"
                           onAction="#handleLogin"/>

            <Region prefHeight="4"/>

            <CheckBox fx:id="rememberMeCheck" text="Ghi nhớ đăng nhập"
                      style="-fx-text-fill: #b5bac1; -fx-font-size: 13px;"/>

            <Label fx:id="errorLabel" styleClass="label-error" wrapText="true" maxWidth="Infinity" visible="false"
                   managed="false"/>

            <Region prefHeight="10"/>

            <Button fx:id="loginButton" text="Đăng nhập" styleClass="button-primary" maxWidth="Infinity"
                    onAction="#handleLogin"/>

            <Region prefHeight="6"/>

            <Region styleClass="auth-divider" maxWidth="Infinity"/>

            <HBox alignment="CENTER" spacing="4">
                <padding><Insets top="8"/></padding>
                <Label text="Chưa có tài khoản?"
                       style="-fx-text-fill: #80848e; -fx-font-size: 13px;"/>
                <Button text="Đăng ký ngay" styleClass="button-link" onAction="#switchToRegister"/>
            </HBox>

        </VBox>

        <Label text="© 2026 Micord" styleClass="auth-footer"/>
    </VBox>

</StackPane>
