<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<StackPane xmlns:fx="http://javafx.com/fxml" styleClass="auth-wrapper"
           fx:controller="com.lqc.client.controller.LoginController">

    <VBox styleClass="auth-card" maxWidth="420" maxHeight="500" spacing="8" alignment="CENTER">

        <Label text="Welcome back!" styleClass="label-title"/>
        <Label text="Sign in to continue to LQC Chat" styleClass="label-subtitle"/>

        <Region prefHeight="16"/>

        <Label text="USERNAME" style="-fx-text-fill: #b9bbbe; -fx-font-size: 12px; -fx-font-weight: bold;"
               maxWidth="Infinity" alignment="BOTTOM_LEFT"/>
        <TextField fx:id="usernameField" promptText="Enter your username" maxWidth="Infinity"/>

        <Region prefHeight="4"/>

        <Label text="PASSWORD" style="-fx-text-fill: #b9bbbe; -fx-font-size: 12px; -fx-font-weight: bold;"
               maxWidth="Infinity" alignment="BOTTOM_LEFT"/>
        <PasswordField fx:id="passwordField" promptText="Enter your password" maxWidth="Infinity"
                       onAction="#handleLogin"/>

        <Region prefHeight="4"/>

        <Label fx:id="errorLabel" styleClass="label-error" wrapText="true" maxWidth="Infinity" visible="false"
               managed="false"/>

        <Region prefHeight="8"/>

        <Button fx:id="loginButton" text="Log In" styleClass="button-primary" maxWidth="Infinity"
                onAction="#handleLogin"/>

        <HBox alignment="CENTER" spacing="4">
            <padding><Insets top="8"/></padding>
            <Label text="Don't have an account?" style="-fx-text-fill: #72767d; -fx-font-size: 13px;"/>
            <Button text="Register" styleClass="button-link" onAction="#switchToRegister"/>
        </HBox>

    </VBox>
</StackPane>
